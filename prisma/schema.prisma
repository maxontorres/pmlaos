generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  agent
}

enum PropertyCategory {
  house
  apartment
  land
  hotel
}

enum TransactionType {
  sale
  rent
}

enum ListingStatus {
  available
  sold
  rented
  hidden
}

enum PriceUnit {
  total
  per_day
  per_week
  per_month
  per_three_months
  per_six_months
  per_year
}

enum ClientStatus {
  new
  active
  closed
  lost
}

enum InterestType {
  any
  house_rent
  apartment_rent
  house_sale
  apartment_sale
  land_sale
}

enum ClientSource {
  website
  referral
  direct
  other
}

enum InquiryStatus {
  new
  contacted
  converted
  closed
}

enum ClientLanguage {
  en
  lo
  zh
  other
}

model Village {
  id        String    @id @default(uuid())
  nameEn    String    @unique
  nameLo    String
  nameZh    String
  slug      String    @unique
  active    Boolean   @default(true)
  order     Int       @default(0)
  listings  Listing[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(agent)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clients       Client[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Listing {
  id               String           @id @default(uuid())
  slug             String           @unique
  category         PropertyCategory
  transaction      TransactionType
  status           ListingStatus    @default(available)
  featured         Boolean          @default(false)
  /// 🎯 SPONSORED: Premium homepage placement - highly visible promotional banner
  sponsored        Boolean          @default(false)
  sponsoredUntil   DateTime?
  villageId        String?
  village          Village?         @relation(fields: [villageId], references: [id])
  titleEn          String
  titleLo          String
  titleZh          String
  descriptionEn    String           @db.Text
  descriptionLo    String           @db.Text
  descriptionZh    String           @db.Text
  district         String?
  price            Decimal          @db.Decimal(12, 2)
  priceUnit        PriceUnit        @default(total)
  areaSqm          Decimal?         @db.Decimal(10, 2)
  bedrooms         Int?
  bathrooms        Int?
  parkingAvailable Boolean          @default(false)
  swimmingPool     Boolean          @default(false)
  hasFitness       Boolean          @default(false)
  amenities        String[]         @default([])
  lat              Decimal?         @db.Decimal(10, 7)
  lng              Decimal?         @db.Decimal(10, 7)
  photos           Photo[]
  inquiries        Inquiry[]
  clientListings   ClientListing[]
  deals            Deal[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Photo {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Client {
  id            String          @id @default(uuid())
  name          String
  whatsapp      String
  email         String?
  nationality   String?
  gender        String?
  speakLaoThai  Boolean         @default(false)
  speakEnglish  Boolean         @default(false)
  language      ClientLanguage  @default(en)
  interestType  InterestType    @default(any)
  budgetMin     Decimal?        @db.Decimal(12, 2)
  budgetMax     Decimal?        @db.Decimal(12, 2)
  notes         String?         @db.Text
  status        ClientStatus    @default(new)
  source        ClientSource    @default(direct)
  lastContactAt DateTime?
  assignedTo    String?
  agent         User?           @relation(fields: [assignedTo], references: [id])
  listings      ClientListing[]
  deals         Deal[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ClientListing {
  clientId  String
  listingId String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([clientId, listingId])
}

model Inquiry {
  id        String        @id @default(uuid())
  name      String
  phone     String
  message   String        @db.Text
  listingId String?
  listing   Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  status    InquiryStatus @default(new)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Deal {
  id              String          @id @default(cuid())
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id])
  listingId       String
  listing         Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  transactionType TransactionType
  dealValue       Float
  commission      Float
  currency        String          @default("USD")
  commissionUsd   Float
  closedAt        DateTime
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
